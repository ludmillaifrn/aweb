style : 
*{ 
    padding : 0px; 
    margin :0px;  
}

.mae{
    border: 1px solid red; 
    height:300px;
    width: 600px; 
    background-color: beige;
}


.circulo1 , .circulo2 , .circulo3  {
    border: 1px solid pink; 
    height:100px;
    width: 100px; 
    position: sticky;
    border-radius: 50%;
    top:50px; 
    background-color: chocolate;
}

.circulo1 {
    left : 25px;
}     
.circulo2 {
    left : 135px;
    
}
.circulo3 {
    left : 255px; 
    position: relative;
    
}
